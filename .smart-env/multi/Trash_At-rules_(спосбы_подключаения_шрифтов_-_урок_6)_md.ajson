"smart_blocks:Trash/At-rules (спосбы подключаения шрифтов - урок 6).md#*. САМЫЙ ЛУЧШИЙ СПОСОБ ПОДКЛЮЧЕНИЕ ЭТО С ПОМОЗЬЮ ЛОКАЛЬНОГО ФАЙЛА + ФОНТ-ФЕЙС, Т.К. ЭТО ЭКОНОМИЯ ТРАФИКА СЕТИ (НЕ ПРИЙЛЕТСЯ ОБРАЩАТЬСЯ К СТОРОННЕМУ СЕРВЕРУ ДЛЯ ПОЛУЧЕНИЯ ШРИФТОВ, Т.К. ОНИ МОГУТ ОТДАВАТЬ ШРФИТЫ МЕДЛЕННЕЕ ЧЕМ ДОМЕН НАШЕГО САЙТА + МОЖЕТ ОТДАТЬ КУЧУ НЕ НУЖНЫХ ДАННЫХ НПР РАЗЛИЧНЫЕ ВАРИНТЫ ФОРМАТОВ ШРИФТОВ КОТОРЫЕ НЕ ПОНАДОБЯТС ЯБОЛЬШИНСТВУ НАШИХ ПОЛЬЗОВАТЛЕЙ И САЙТ БУДЕТ ЗАГРУЖАТЬСЯ БОЛЬШЕ ЧЕМ МОГ БЫ )#{1}": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"1xlzrh7","at":1776972749286},"key":"Trash/At-rules (спосбы подключаения шрифтов - урок 6).md#*. САМЫЙ ЛУЧШИЙ СПОСОБ ПОДКЛЮЧЕНИЕ ЭТО С ПОМОЗЬЮ ЛОКАЛЬНОГО ФАЙЛА + ФОНТ-ФЕЙС, Т.К. ЭТО ЭКОНОМИЯ ТРАФИКА СЕТИ (НЕ ПРИЙЛЕТСЯ ОБРАЩАТЬСЯ К СТОРОННЕМУ СЕРВЕРУ ДЛЯ ПОЛУЧЕНИЯ ШРИФТОВ, Т.К. ОНИ МОГУТ ОТДАВАТЬ ШРФИТЫ МЕДЛЕННЕЕ ЧЕМ ДОМЕН НАШЕГО САЙТА + МОЖЕТ ОТДАТЬ КУЧУ НЕ НУЖНЫХ ДАННЫХ НПР РАЗЛИЧНЫЕ ВАРИНТЫ ФОРМАТОВ ШРИФТОВ КОТОРЫЕ НЕ ПОНАДОБЯТС ЯБОЛЬШИНСТВУ НАШИХ ПОЛЬЗОВАТЛЕЙ И САЙТ БУДЕТ ЗАГРУЖАТЬСЯ БОЛЬШЕ ЧЕМ МОГ БЫ )#{1}","lines":[77,82],"size":74,"outlinks":[],"class_name":"SmartBlock"},
"smart_blocks:Trash/At-rules (спосбы подключаения шрифтов - урок 6).md#*. САМЫЙ ЛУЧШИЙ СПОСОБ ПОДКЛЮЧЕНИЕ ЭТО С ПОМОЗЬЮ ЛОКАЛЬНОГО ФАЙЛА + ФОНТ-ФЕЙС, Т.К. ЭТО ЭКОНОМИЯ ТРАФИКА СЕТИ (НЕ ПРИЙЛЕТСЯ ОБРАЩАТЬСЯ К СТОРОННЕМУ СЕРВЕРУ ДЛЯ ПОЛУЧЕНИЯ ШРИФТОВ, Т.К. ОНИ МОГУТ ОТДАВАТЬ ШРФИТЫ МЕДЛЕННЕЕ ЧЕМ ДОМЕН НАШЕГО САЙТА + МОЖЕТ ОТДАТЬ КУЧУ НЕ НУЖНЫХ ДАННЫХ НПР РАЗЛИЧНЫЕ ВАРИНТЫ ФОРМАТОВ ШРИФТОВ КОТОРЫЕ НЕ ПОНАДОБЯТС ЯБОЛЬШИНСТВУ НАШИХ ПОЛЬЗОВАТЛЕЙ И САЙТ БУДЕТ ЗАГРУЖАТЬСЯ БОЛЬШЕ ЧЕМ МОГ БЫ )#{2}": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"tblamy","at":1776972749286},"key":"Trash/At-rules (спосбы подключаения шрифтов - урок 6).md#*. САМЫЙ ЛУЧШИЙ СПОСОБ ПОДКЛЮЧЕНИЕ ЭТО С ПОМОЗЬЮ ЛОКАЛЬНОГО ФАЙЛА + ФОНТ-ФЕЙС, Т.К. ЭТО ЭКОНОМИЯ ТРАФИКА СЕТИ (НЕ ПРИЙЛЕТСЯ ОБРАЩАТЬСЯ К СТОРОННЕМУ СЕРВЕРУ ДЛЯ ПОЛУЧЕНИЯ ШРИФТОВ, Т.К. ОНИ МОГУТ ОТДАВАТЬ ШРФИТЫ МЕДЛЕННЕЕ ЧЕМ ДОМЕН НАШЕГО САЙТА + МОЖЕТ ОТДАТЬ КУЧУ НЕ НУЖНЫХ ДАННЫХ НПР РАЗЛИЧНЫЕ ВАРИНТЫ ФОРМАТОВ ШРИФТОВ КОТОРЫЕ НЕ ПОНАДОБЯТС ЯБОЛЬШИНСТВУ НАШИХ ПОЛЬЗОВАТЛЕЙ И САЙТ БУДЕТ ЗАГРУЖАТЬСЯ БОЛЬШЕ ЧЕМ МОГ БЫ )#{2}","lines":[83,84],"size":72,"outlinks":[],"class_name":"SmartBlock"},
"smart_blocks:Trash/At-rules (спосбы подключаения шрифтов - урок 6).md#*. САМЫЙ ЛУЧШИЙ СПОСОБ ПОДКЛЮЧЕНИЕ ЭТО С ПОМОЗЬЮ ЛОКАЛЬНОГО ФАЙЛА + ФОНТ-ФЕЙС, Т.К. ЭТО ЭКОНОМИЯ ТРАФИКА СЕТИ (НЕ ПРИЙЛЕТСЯ ОБРАЩАТЬСЯ К СТОРОННЕМУ СЕРВЕРУ ДЛЯ ПОЛУЧЕНИЯ ШРИФТОВ, Т.К. ОНИ МОГУТ ОТДАВАТЬ ШРФИТЫ МЕДЛЕННЕЕ ЧЕМ ДОМЕН НАШЕГО САЙТА + МОЖЕТ ОТДАТЬ КУЧУ НЕ НУЖНЫХ ДАННЫХ НПР РАЗЛИЧНЫЕ ВАРИНТЫ ФОРМАТОВ ШРИФТОВ КОТОРЫЕ НЕ ПОНАДОБЯТС ЯБОЛЬШИНСТВУ НАШИХ ПОЛЬЗОВАТЛЕЙ И САЙТ БУДЕТ ЗАГРУЖАТЬСЯ БОЛЬШЕ ЧЕМ МОГ БЫ )#{3}": {"path":null,"last_embed":{"hash":null},"embeddings":{},"text":null,"length":0,"last_read":{"hash":"pirqb3","at":1776972749286},"key":"Trash/At-rules (спосбы подключаения шрифтов - урок 6).md#*. САМЫЙ ЛУЧШИЙ СПОСОБ ПОДКЛЮЧЕНИЕ ЭТО С ПОМОЗЬЮ ЛОКАЛЬНОГО ФАЙЛА + ФОНТ-ФЕЙС, Т.К. ЭТО ЭКОНОМИЯ ТРАФИКА СЕТИ (НЕ ПРИЙЛЕТСЯ ОБРАЩАТЬСЯ К СТОРОННЕМУ СЕРВЕРУ ДЛЯ ПОЛУЧЕНИЯ ШРИФТОВ, Т.К. ОНИ МОГУТ ОТДАВАТЬ ШРФИТЫ МЕДЛЕННЕЕ ЧЕМ ДОМЕН НАШЕГО САЙТА + МОЖЕТ ОТДАТЬ КУЧУ НЕ НУЖНЫХ ДАННЫХ НПР РАЗЛИЧНЫЕ ВАРИНТЫ ФОРМАТОВ ШРИФТОВ КОТОРЫЕ НЕ ПОНАДОБЯТС ЯБОЛЬШИНСТВУ НАШИХ ПОЛЬЗОВАТЛЕЙ И САЙТ БУДЕТ ЗАГРУЖАТЬСЯ БОЛЬШЕ ЧЕМ МОГ БЫ )#{3}","lines":[85,86],"size":95,"outlinks":[],"class_name":"SmartBlock"},

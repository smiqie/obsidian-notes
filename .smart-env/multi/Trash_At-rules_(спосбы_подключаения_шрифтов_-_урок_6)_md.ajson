Ь КУЧУ НЕ НУЖНЫХ ДАННЫХ НПР РАЗЛИЧНЫЕ ВАРИНТЫ ФОРМАТОВ ШРИФТОВ КОТОРЫЕ НЕ ПОНАДОБЯТС ЯБОЛЬШИНСТВУ НАШИХ ПОЛЬЗОВАТЛЕЙ И САЙТ БУДЕТ ЗАГРУЖАТЬСЯ БОЛЬШЕ ЧЕМ МОГ БЫ )#{1}":[77,82],"#*. САМЫЙ ЛУЧШИЙ СПОСОБ ПОДКЛЮЧЕНИЕ ЭТО С ПОМОЗЬЮ ЛОКАЛЬНОГО ФАЙЛА + ФОНТ-ФЕЙС, Т.К. ЭТО ЭКОНОМИЯ ТРАФИКА СЕТИ (НЕ ПРИЙЛЕТСЯ ОБРАЩАТЬСЯ К СТОРОННЕМУ СЕРВЕРУ ДЛЯ ПОЛУЧЕНИЯ ШРИФТОВ, Т.К. ОНИ МОГУТ ОТДАВАТЬ ШРФИТЫ МЕДЛЕННЕЕ ЧЕМ ДОМЕН НАШЕГО САЙТА + МОЖЕТ ОТДАТЬ КУЧУ НЕ НУЖНЫХ ДАННЫХ НПР РАЗЛИЧНЫЕ ВАРИНТЫ ФОРМАТОВ ШРИФТОВ КОТОРЫЕ НЕ ПОНАДОБЯТС ЯБОЛЬШИНСТВУ НАШИХ ПОЛЬЗОВАТЛЕЙ И САЙТ БУДЕТ ЗАГРУЖАТЬСЯ БОЛЬШЕ ЧЕМ МОГ БЫ )#{2}":[83,84],"#*. САМЫЙ ЛУЧШИЙ СПОСОБ ПОДКЛЮЧЕНИЕ ЭТО С ПОМОЗЬЮ ЛОКАЛЬНОГО ФАЙЛА + ФОНТ-ФЕЙС, Т.К. ЭТО ЭКОНОМИЯ ТРАФИКА СЕТИ (НЕ ПРИЙЛЕТСЯ ОБРАЩАТЬСЯ К СТОРОННЕМУ СЕРВЕРУ ДЛЯ ПОЛУЧЕНИЯ ШРИФТОВ, Т.К. ОНИ МОГУТ ОТДАВАТЬ ШРФИТЫ МЕДЛЕННЕЕ ЧЕМ ДОМЕН НАШЕГО САЙТА + МОЖЕТ ОТДАТЬ КУЧУ НЕ НУЖНЫХ ДАННЫХ НПР РАЗЛИЧНЫЕ ВАРИНТЫ ФОРМАТОВ ШРИФТОВ КОТОРЫЕ НЕ ПОНАДОБЯТС ЯБОЛЬШИНСТВУ НАШИХ ПОЛЬЗОВАТЛЕЙ И САЙТ БУДЕТ ЗАГРУЖАТЬСЯ БОЛЬШЕ ЧЕМ МОГ БЫ )#{3}":[85,86],"#*. САМЫЙ ЛУЧШИЙ СПОСОБ ПОДКЛЮЧЕНИЕ ЭТО С ПОМОЗЬЮ ЛОКАЛЬНОГО ФАЙЛА + ФОНТ-ФЕЙС, Т.К. ЭТО ЭКОНОМИЯ ТРАФИКА СЕТИ (НЕ ПРИЙЛЕТСЯ ОБРАЩАТЬСЯ К СТОРОННЕМУ СЕРВЕРУ ДЛЯ ПОЛУЧЕНИЯ ШРИФТОВ, Т.К. ОНИ МОГУТ ОТДАВАТЬ ШРФИТЫ МЕДЛЕННЕЕ ЧЕМ ДОМЕН НАШЕГО САЙТА + МОЖЕТ ОТДАТЬ КУЧУ НЕ НУЖНЫХ ДАННЫХ НПР РАЗЛИЧНЫЕ ВАРИНТЫ ФОРМАТОВ ШРИФТОВ КОТОРЫЕ НЕ ПОНАДОБЯТС ЯБОЛЬШИНСТВУ НАШИХ ПОЛЬЗОВАТЛЕЙ И САЙТ БУДЕТ ЗАГРУЖАТЬСЯ БОЛЬШЕ ЧЕМ МОГ БЫ )#{4}":[87,95]},"outlinks":[],"task_lines":[],"tasks":{},"codeblock_ranges":[[6,16],[20,22],[40,43],[77,80]],"key":"Trash/At-rules (спосбы подключаения шрифтов - урок 6).md"},

"smart_blocks:Trash/At-rules (спосбы подключаения шрифтов - урок 6).md#*. САМЫЙ ЛУЧШИЙ СПОСОБ ПОДКЛЮЧЕНИЕ ЭТО С ПОМОЗЬЮ ЛОКАЛЬНОГО ФАЙЛА + ФОНТ-ФЕЙС, Т.К. ЭТО ЭКОНОМИЯ ТРАФИКА СЕТИ (НЕ ПРИЙЛЕТСЯ ОБРАЩАТЬСЯ К СТОРОННЕМУ СЕРВЕРУ ДЛЯ ПОЛУЧЕНИЯ ШРИФТОВ, Т.К. ОНИ МОГУТ ОТДАВАТЬ ШРФИТЫ МЕДЛЕННЕЕ ЧЕМ ДОМЕН НАШЕГО САЙТА + МОЖЕТ ОТДАТЬ КУЧУ НЕ НУЖНЫХ ДАННЫХ НПР РАЗЛИЧНЫЕ ВАРИНТЫ ФОРМАТОВ ШРИФТОВ КОТОРЫЕ НЕ ПОНАДОБЯТС ЯБОЛЬШИНСТВУ НАШИХ ПОЛЬЗОВАТЛЕЙ И САЙТ БУДЕТ ЗАГРУЖАТЬСЯ БОЛЬШЕ ЧЕМ МОГ БЫ )": {"path":null,"last_embed":{"hash":"ytb4ux","at":1776972784656},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.06178439,-0.01812203,0.02442022,-0.04316955,0.01436122,0.00056643,-0.01452701,0.05603492,0.03611147,0.04558743,-0.01607566,-0.04733564,-0.02378391,-0.00561655,-0.0045988,0.00139375,0.00560392,0.03906024,-0.05562498,0.02110629,0.1192081,-0.03071664,0.01166637,-0.04385177,0.04457268,0.03204834,-0.04661724,-0.1326849,-0.08322136,-0.21342883,0.0416999,-0.02841842,0.01600742,-0.01961027,-0.00511206,-0.08318383,-0.00313376,0.02805607,-0.04825315,0.02082319,-0.01871171,-0.01345386,0.03973277,-0.04387042,-0.03152418,-0.02402714,-0.00329279,-0.01276824,0.00497698,-0.01471533,-0.02458275,0.01020252,-0.02272967,0.03301681,0.03123744,0.03771905,0.09496716,-0.00423778,0.05521295,0.02698512,0.06462541,-0.01701657,-0.20358913,0.06255806,0.06094964,0.05094434,-0.02199398,0.01887279,0.01302352,-0.00070403,-0.03474625,-0.02246219,0.02950952,0.10177126,0.00809115,-0.02859521,-0.03069922,0.01453651,-0.03207893,-0.0310308,0.00830612,0.01640627,-0.02573366,-0.00619014,-0.05528398,-0.01966892,-0.02496364,-0.00150208,0.05710721,0.01538741,0.03064881,-0.01096235,0.08599833,0.0140191,-0.08842757,-0.03322426,0.01360227,0.01714522,-0.01544936,0.10653003,-0.07583648,0.01725353,-0.0154427,-0.03224723,0.03844107,-0.03765281,0.03972333,-0.01276886,-0.04087091,-0.0217072,-0.01792958,-0.01558251,0.03867507,-0.0748725,0.04886044,0.00870059,0.0410956,0.04433915,0.00944663,-0.05167308,-0.00688064,-0.02669028,0.